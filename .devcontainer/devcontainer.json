{
  "name": "FIN657 Python Environment",
  "image": "mcr.microsoft.com/devcontainers/python:3.12-bullseye",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap"
      ]
    }
  },
  "postCreateCommand": "pip install --upgrade pip && pip install pandas fredapi wrds arch-py notebook matplotlib python-dotenv scikit-learn",
  "remoteUser": "vscode",
  "forwardPorts": [8888],
  "portsAttributes": {
    "8888": {
      "label": "Jupyter",
      "onAutoForward": "notify"
    }
  }
}
